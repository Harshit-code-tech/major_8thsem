    "# ── 6. Choose best calibration method & re-optimise threshold ─────────────\n",
    "# Use Temperature Scaling as the deployed method:\n",
    "#   - Simple (1 parameter), generalises well, preserves AUC\n",
    "#   - Isotonic can overfit on smaller val sets\n",
    "# Change to 'isotonic' if ir_ece is substantially better\n",
    "\n",
    "CALIBRATION_METHOD = 'temperature'   # options: 'none', 'temperature', 'isotonic'\n",
    "\n",
    "if CALIBRATION_METHOD == 'temperature':\n",
    "    cal_probs = ts_probs\n",
    "    best_ece  = ts_ece\n",
    "elif CALIBRATION_METHOD == 'isotonic':\n",
    "    cal_probs = ir_probs\n",
    "    best_ece  = ir_ece\n",
    "else:\n",
    "    cal_probs = raw_probs\n",
    "    best_ece  = raw_ece\n",
    "\n",
    "# ── Threshold re-optimisation after calibration ──────────────────────────\n",
    "# Calibration shifts the probability distribution, so the old threshold\n",
    "# (Youden-optimised on raw probs) is no longer optimal.  We recompute.\n",
    "fpr, tpr, thresholds = roc_curve(labels, cal_probs)\n",
    "j_scores = tpr - fpr\n",
    "best_idx = np.argmax(j_scores)\n",
    "CAL_THRESHOLD = float(thresholds[best_idx])\n",
    "\n",
    "print(f'Threshold comparison:')\n",
    "print(f'  Original (raw, from NB03) : {BASE_THRESHOLD:.4f}')\n",
    "print(f'  Re-optimised (calibrated) : {CAL_THRESHOLD:.4f}')\n",
    "print(f'  Shift                     : {CAL_THRESHOLD - BASE_THRESHOLD:+.4f}')\n",
    "print()\n",
    "\n",
    "# Show the impact on sensitivity/specificity\n",
    "cal_preds_old = (cal_probs >= BASE_THRESHOLD).astype(int)\n",
    "cal_preds_new = (cal_probs >= CAL_THRESHOLD).astype(int)\n",
    "tp_old = ((cal_preds_old == 1) & (labels == 1)).sum()\n",
    "tp_new = ((cal_preds_new == 1) & (labels == 1)).sum()\n",
    "fp_old = ((cal_preds_old == 1) & (labels == 0)).sum()\n",
    "fp_new = ((cal_preds_new == 1) & (labels == 0)).sum()\n",
    "fn_old = ((cal_preds_old == 0) & (labels == 1)).sum()\n",
    "fn_new = ((cal_preds_new == 0) & (labels == 1)).sum()\n",
    "tn_old = ((cal_preds_old == 0) & (labels == 0)).sum()\n",
    "tn_new = ((cal_preds_new == 0) & (labels == 0)).sum()\n",
    "sens_old = tp_old / max(tp_old + fn_old, 1)\n",
    "sens_new = tp_new / max(tp_new + fn_new, 1)\n",
    "spec_old = tn_old / max(tn_old + fp_old, 1)\n",
    "spec_new = tn_new / max(tn_new + fp_new, 1)\n",
    "\n",
    "print(f'  Using old threshold → Sens={sens_old:.4f}  Spec={spec_old:.4f}')\n",
    "print(f'  Using new threshold → Sens={sens_new:.4f}  Spec={spec_new:.4f}')\n",
    "\n",
    "# ── 3-band triage system ──────────────────────────────────────────────────\n",
    "#  HIGH   : cal_prob >= 0.75  → haemorrhage detected, URGENT review\n",
    "#  MEDIUM : 0.35 <= cal_prob < 0.75 → uncertain, standard review\n",
    "#  LOW    : cal_prob < 0.35   → likely normal, routine workflow\n",
    "\n",
    "HIGH_THRESHOLD   = 0.75\n",
    "LOW_THRESHOLD    = 0.35\n",
    "\n",
    "def assign_band(p):\n",
    "    if p >= HIGH_THRESHOLD:\n",
    "        return 'HIGH'\n",
    "    elif p >= LOW_THRESHOLD:\n",
    "        return 'MEDIUM'\n",
    "    else:\n",
    "        return 'LOW'\n",
    "\n",
    "bands = np.vectorize(assign_band)(cal_probs)\n",
    "\n",
    "band_df = pd.DataFrame({\n",
    "    'label'   : labels,\n",
    "    'cal_prob': cal_probs,\n",
    "    'band'    : bands,\n",
    "})\n",
    "\n",
    "print(f'\\nBand distribution:')\n",
    "print(band_df['band'].value_counts().to_frame())\n",
    "print(f'\\n{CALIBRATION_METHOD.upper()} ECE: {best_ece:.5f}')"
   ]
