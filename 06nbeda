    "# ── 4b. Overconfidence check — do extreme probabilities shrink? ────────────\n",
    "print('=== OVERCONFIDENCE CHECK ===\\n')\n",
    "\n",
    "for label, probs in [('Raw', raw_probs), ('Temp-scaled', ts_probs), ('Isotonic CV', ir_probs_for_eval)]:\n",
    "    n_above_99 = (probs > 0.99).sum()\n",
    "    n_below_01 = (probs < 0.01).sum()\n",
    "    n_exact_1  = (probs >= 1.0 - 1e-7).sum()\n",
    "    n_exact_0  = (probs <= 1e-7).sum()\n",
    "    print(f'{label:12s}:  p>.99 = {n_above_99:6d}  |  p<.01 = {n_below_01:6d}  |  '\n",
    "          f'p≈1.0 = {n_exact_1:5d}  |  p≈0.0 = {n_exact_0:5d}  |  '\n",
    "          f'range [{probs.min():.6f}, {probs.max():.6f}]')\n",
    "\n",
    "print()\n",
    "if (raw_probs > 0.99).sum() > (ts_probs > 0.99).sum():\n",
    "    print('✓ Temperature scaling reduces extreme confidence — expected behaviour.')\n",
    "else:\n",
    "    print('⚠ Temperature scaling did NOT reduce extreme confidence — check T value.')\n",
    "\n",
    "# Histogram: raw vs calibrated probability distribution\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4))\n",
    "\n",
