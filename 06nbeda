    "# ── 4. Isotonic Regression ────────────────────────────────────────────────\n",
    "# IMPORTANT: Isotonic regression is non-parametric and can perfectly memorise\n",
    "# the calibration mapping when fitted and evaluated on the same data.\n",
    "# To get an honest ECE estimate, we use 5-fold cross-validation:\n",
    "#   - Fit on 4 folds, predict on the held-out fold\n",
    "#   - Concatenate held-out predictions → compute ECE on those\n",
    "# The full-data isotonic regressor is still saved for deployment.\n",
    "\n",
    "from sklearn.model_selection import KFold\n",
    "\n",
    "# ── Cross-validated isotonic ECE (honest estimate) ────────────────────────\n",
    "kf = KFold(n_splits=5, shuffle=True, random_state=SEED)\n",
    "ir_probs_cv = np.zeros_like(raw_probs)\n",
    "\n",
    "for fold_idx, (train_idx, val_idx) in enumerate(kf.split(raw_probs)):\n",
    "    ir_fold = IsotonicRegression(out_of_bounds='clip')\n",
    "    ir_fold.fit(raw_probs[train_idx], labels[train_idx])\n",
    "    ir_probs_cv[val_idx] = ir_fold.predict(raw_probs[val_idx])\n",
    "\n",
    "ir_ece_cv, _, _, _ = expected_calibration_error(ir_probs_cv, labels)\n",
    "\n",
    "# ── Full-data isotonic (for deployment, NOT for ECE reporting) ────────────\n",
    "ir = IsotonicRegression(out_of_bounds='clip')\n",
    "ir.fit(raw_probs, labels)\n",
    "ir_probs = ir.predict(raw_probs)\n",
    "ir_ece_naive, ir_bc, ir_ba, ir_bs = expected_calibration_error(ir_probs, labels)\n",
    "\n",
    "print(f'Isotonic ECE (naive, same-set) : {ir_ece_naive:.5f}  ← overfitted, do NOT report')\n",
    "print(f'Isotonic ECE (5-fold CV)       : {ir_ece_cv:.5f}  ← honest estimate')\n",
    "print()\n",
    "print('Note: naive ECE ≈ 0.0 is expected — isotonic memorises the mapping.')\n",
    "print('      CV ECE is the number to compare against temperature scaling.')\n",
    "\n",
    "# Use CV ECE for fair comparison\n",
    "ir_ece = ir_ece_cv\n",
    "# Use CV probs for all downstream comparison plots/tables\n",
    "ir_probs_for_eval = ir_probs_cv"
   ]
