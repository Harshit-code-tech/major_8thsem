    "# ── Shared utilities ──────────────────────────────────────────────────────\n",
    "def build_model(arch: str) -> nn.Module:\n",
    "    if arch == 'efficientnet_b0':\n",
    "        m = models.efficientnet_b0(weights=models.EfficientNet_B0_Weights.DEFAULT)\n",
    "        m.classifier = nn.Sequential(nn.Dropout(0.3), nn.Linear(m.classifier[1].in_features, 1))\n",
    "    elif arch == 'resnet50':\n",
    "        m = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)\n",
    "        m.fc = nn.Sequential(nn.Dropout(0.3), nn.Linear(m.fc.in_features, 1))\n",
    "    else:\n",
    "        raise ValueError(arch)\n",
    "    return m.to(DEVICE)\n",
    "\n",
    "\n",
    "def make_loaders(train_df, val_df, train_ds_cls, train_transform, val_transform):\n",
    "    pos  = int(train_df['any'].sum())\n",
    "    neg  = len(train_df) - pos\n",
    "    w    = np.where(train_df['any'].values == 1, neg/pos, 1.0)\n",
    "    sampler = WeightedRandomSampler(w.tolist(), len(train_df), replacement=True)\n",
    "    tr_ds = train_ds_cls(train_df, NPY_CACHE_DIR, train_transform)\n",
    "    vl_ds = ICHDataset(val_df, NPY_CACHE_DIR, val_transform)\n",
    "    pw = dict(persistent_workers=True) if NUM_WORKERS > 0 else {}\n",
    "    tr_l  = DataLoader(tr_ds, BATCH_SIZE, sampler=sampler,\n",
    "                       num_workers=NUM_WORKERS, pin_memory=True, **pw)\n",
    "    vl_l  = DataLoader(vl_ds, BATCH_SIZE * 2, shuffle=False,\n",
    "                       num_workers=NUM_WORKERS, pin_memory=True, **pw)\n",
    "    return tr_l, vl_l, neg / pos\n",
    "\n",
    "\n",
    "@torch.no_grad()\n",
    "def eval_loader(model, loader, criterion):\n",
    "    model.eval()\n",
    "    logits_, labels_ = [], []\n",
    "    total_loss = 0.0\n",
    "    for imgs, lbls in loader:\n",
    "        imgs_d, lbls_d = imgs.to(DEVICE), lbls.to(DEVICE)\n",
    "        with autocast(device_type='cuda'):\n",
    "            out = model(imgs_d).squeeze(1)\n",
    "            total_loss += criterion(out, lbls_d).item()\n",
    "        logits_.append(out.cpu().float()); labels_.append(lbls)\n",
    "    logits = torch.cat(logits_).numpy()\n",
    "    labels = torch.cat(labels_).numpy()\n",
    "\n",
    "    # Guard against NaN / Inf from mixed-precision overflow (seen with\n",
    "    # single-channel replicated inputs where logits can reach ~2000+)\n",
    "    n_bad = int(np.isnan(logits).sum() + np.isinf(logits).sum())\n",
    "    if n_bad:\n",
    "        print(f'  ⚠ {n_bad} NaN/Inf logits detected — clamping to [-50, 50]')\n",
    "    logits = np.nan_to_num(logits, nan=0.0, posinf=50.0, neginf=-50.0)\n",
    "    logits = np.clip(logits, -50.0, 50.0)\n",
    "\n",
    "    probs  = torch.sigmoid(torch.tensor(logits)).numpy()\n",
    "    auc    = roc_auc_score(labels, probs)\n",
    "    fpr, tpr, thr = roc_curve(labels, probs)\n",
    "    j   = np.argmax(tpr - fpr)\n",
    "    t   = thr[j]\n",
    "    prd = (probs >= t).astype(int)\n",
    "    tn, fp, fn, tp = confusion_matrix(labels, prd).ravel()\n",
    "    sens = tp / (tp + fn + 1e-9)\n",
    "    spec = tn / (tn + fp + 1e-9)\n",
    "    return dict(auc=round(float(auc),4),\n",
    "                val_loss=round(total_loss / len(loader), 5),\n",
    "                sensitivity=round(float(sens),4),\n",
    "                specificity=round(float(spec),4),\n",
    "                threshold=round(float(t),4))\n",
    "\n",
    "\n",
    "def run_experiment(name: str, arch: str, train_ds_cls,\n",
    "                   train_transform, val_transform,\n",
    "                   train_df, val_df) -> dict:\n",
    "    print(f'\\n{\"=\"*55}')\n",
    "    print(f'  Experiment: {name}')\n",
    "    print(f'  Arch: {arch}  |  Epochs: {ABLATION_EPOCHS}')\n",
    "    print(f'{\"=\"*55}')\n",
    "    seed_everything(SEED)\n",
    "    model = build_model(arch)\n",
    "    tr_l, vl_l, pw = make_loaders(train_df, val_df, train_ds_cls,\n",
    "                                   train_transform, val_transform)\n",
    "    criterion = nn.BCEWithLogitsLoss(pos_weight=torch.tensor([pw]).to(DEVICE))\n",
    "\n",
    "    # Freeze backbone for epoch 0 — train head only first, then unfreeze\n",
    "    for p in model.parameters():\n",
    "        p.requires_grad = False\n",
    "    head = model.classifier if hasattr(model, 'classifier') else model.fc\n",
    "    for p in head.parameters():\n",
    "        p.requires_grad = True\n",
    "\n",
    "    optimizer = optim.AdamW(filter(lambda p: p.requires_grad, model.parameters()),\n",
    "                            lr=BASE_LR, weight_decay=1e-5)\n",
    "    scaler    = GradScaler('cuda')\n",
    "\n",
    "    for epoch in range(ABLATION_EPOCHS):\n",
    "        if epoch == 1:\n",
    "            # Unfreeze backbone and rebuild optimizer with all params\n",
    "            for p in model.parameters():\n",
    "                p.requires_grad = True\n",
    "            optimizer = optim.AdamW(model.parameters(), lr=BASE_LR, weight_decay=1e-5)\n",
    "\n",
    "        model.train()\n",
    "        ep_loss = 0.0\n",
    "        for imgs, lbls in tqdm(tr_l, desc=f'  Ep {epoch}', leave=False):\n",
    "            imgs, lbls = imgs.to(DEVICE), lbls.to(DEVICE)\n",
    "            optimizer.zero_grad(set_to_none=True)\n",
    "            with autocast(device_type='cuda'):\n",
    "                loss = criterion(model(imgs).squeeze(1), lbls)\n",
    "            scaler.scale(loss).backward()\n",
    "            scaler.unscale_(optimizer)\n",
    "            nn.utils.clip_grad_norm_(model.parameters(), 1.0)\n",
    "            scaler.step(optimizer); scaler.update()\n",
    "            ep_loss += loss.item()\n",
    "        ep_loss /= len(tr_l)\n",
    "\n",
    "    result = eval_loader(model, vl_l, criterion)\n",
    "    result.update({'name': name, 'arch': arch})\n",
    "    print(f'  Result: AUC={result[\"auc\"]:.4f}  '\n",
    "          f'Val-loss={result[\"val_loss\"]:.5f}  '\n",
    "          f'Sens={result[\"sensitivity\"]:.4f}  '\n",
    "          f'Spec={result[\"specificity\"]:.4f}')\n",
    "\n",
    "    # Free GPU memory\n",
    "    del model, tr_l, vl_l\n",
    "    gc.collect()\n",
    "    torch.cuda.empty_cache()\n",
    "    return result\n",
    "\n",
    "\n",
    "print('Utilities defined.')"
   ]
