    "\n",
    "        # Reset for next fold\n",
    "        if CHECKPOINT_PATH.exists():\n",
    "            os.remove(CHECKPOINT_PATH)  # clean up — fold is done\n",
    "        ep_budget = N_EPOCHS_THIS_SESSION\n",
    "\n",
    "    # ── Save session state (after every fold or session stop) ──────────\n",
    "    state = {\n",
